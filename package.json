{
  "name": "memelibrary",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "export:web": "expo export --platform web",
    "deploy:web": "expo export --platform web && eas deploy --non-interactive",
    "deploy:web:preview": "expo export --platform web && eas deploy --non-interactive"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@rn-primitives/alert-dialog": "^1.2.0",
    "@rn-primitives/portal": "^1.3.0",
    "@rn-primitives/separator": "^1.2.0",
    "@rn-primitives/slot": "^1.2.0",
    "@shopify/flash-list": "^2.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-file-system": "^55.0.11",
    "expo-font": "~14.0.11",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-media-library": "^55.0.10",
    "expo-router": "~6.0.23",
    "expo-sharing": "^55.0.14",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "^55.0.11",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.16",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.11",
    "prettier": "^3.8.1",
    "react-test-renderer": "^19.1.0",
    "tailwindcss": "~3.4.17",
    "typescript": "~5.9.2"
  },
  "expo": {
    "install": {
      "exclude": [
        "expo-media-library",
        "expo-file-system",
        "expo-sharing"
      ]
    }
  },
  "overrides": {
    "@tootallnate/once": "3.0.1",
    "brace-expansion": ">=1.1.13",
    "node-forge": ">=1.4.0",
    "picomatch": ">=2.3.2",
    "yaml": ">=2.8.3"
  },
  "private": true
}
